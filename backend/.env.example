# Application
APP_NAME="HVAC AI Assistant"
DEBUG=true
ENVIRONMENT=development

# API
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/hvac_assistant

# Redis
REDIS_URL=redis://localhost:6379

# Anthropic
ANTHROPIC_API_KEY=your-anthropic-api-key
ANTHROPIC_MODEL=claude-sonnet-4-20250514
ANTHROPIC_MAX_TOKENS=4096

# Voyage AI (embeddings)
VOYAGE_API_KEY=your-voyage-api-key
VOYAGE_MODEL=voyage-large-2

# Qdrant (vector store)
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=hvac_manuals

# RAG settings
RAG_TOP_K=10
RAG_MIN_SCORE=0.5
CHUNK_SIZE=1500
CHUNK_OVERLAP=200

# Storage
MANUAL_STORAGE_PATH=./data/manuals
UPLOAD_MAX_SIZE_MB=50

# Security
CORS_ORIGINS=["http://localhost:3000"]
